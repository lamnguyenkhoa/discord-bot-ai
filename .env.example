DISCORD_TOKEN=your_token_here
OPENROUTER_API_KEY=your_key_here
MODEL_NAME=openai/gpt-5.4-mini
SUMMARIZE_THRESHOLD=50
WATCH_CHANNELS=general,announcements
WEB_SEARCH_ENABLED=false
# Kill word - stops the bot process when sent by an allowed user
KILL_WORD=stopbot
KILL_WORD_ALLOWED_USER_ID=220740556496699394
# Status messages - sent to STATUS_CHANNEL when bot goes online/offline
ONLINE_MESSAGE=I'm back online!
OFFLINE_MESSAGE=Going offline now. Sayonara!
STATUS_CHANNEL=ai-training-room
ATTACHMENT_MAX_BYTES=524288 #512KB
ATTACHMENT_MAX_CHARS=8000