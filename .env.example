DISCORD_TOKEN=your_token_here

# --- OpenRouter (default) ---
OPENROUTER_API_KEY=your_key_here
# LLM_BASE_URL=https://openrouter.ai/api/v1  # default, can omit
# LLM_API_KEY=your_key_here                  # alternative to OPENROUTER_API_KEY

# --- Ollama local (uncomment to use) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=                               # not required for Ollama

MODEL_NAME=openai/gpt-5.4-mini              # e.g. llama3.2 for Ollama
SUMMARIZE_THRESHOLD=50
WATCH_CHANNELS=general,announcements
WEB_SEARCH_ENABLED=false
# Kill word - stops the bot process when sent by an allowed user
KILL_WORD=stopbot
KILL_WORD_ALLOWED_USER_ID=220740556496699394
# Status messages - sent to STATUS_CHANNEL when bot goes online/offline
ONLINE_MESSAGE=Im back online!
OFFLINE_MESSAGE=Going offline now. Sayonara!
STATUS_CHANNEL=ai-training-room
ATTACHMENT_MAX_BYTES=524288 #512KB
ATTACHMENT_MAX_CHARS=8000
PDF_MAX_BYTES=5242880 #5MB
PDF_MAX_PAGES=20

# --- Embeddings (optional - falls back to FTS5 if not set) ---
# EMBEDDING_API_KEY=your_key_here           # defaults to LLM_API_KEY if not set
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1  # must match LLM provider
# EMBEDDING_MODEL=text-embedding-3-small    # default