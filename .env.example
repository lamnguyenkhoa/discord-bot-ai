DISCORD_TOKEN=your_token_here
OPENROUTER_API_KEY=your_key_here
# Available models on OpenRouter (copy-paste into MODEL_NAME):
# --- Budget ---
# google/gemini-flash-1.5
# meta-llama/llama-3.1-8b-instruct
# mistral/mistral-nemo
# --- Mid-range ---
# anthropic/claude-3-haiku        (recommended for Mal)
# openai/gpt-4o-mini
# openai/gpt-oss-120b
# google/gemini-pro-1.5
# --- Premium ---
# anthropic/claude-3.5-sonnet
# openai/gpt-4o
# meta-llama/llama-3.1-70b-instruct
MODEL_NAME=openai/gpt-4o-mini
SUMMARIZE_THRESHOLD=50
WATCH_CHANNELS=general,announcements

# Kill word - stops the bot process when sent by an allowed user
# KILL_WORD=stopbot
# KILL_WORD_ALLOWED_USER_ID=123456789012345678

# Status messages - sent to STATUS_CHANNEL when bot goes online/offline
# ONLINE_MESSAGE=I'm back online!
# OFFLINE_MESSAGE=Going offline now. Goodbye!
# STATUS_CHANNEL=general


# Model rating:
# deepseek/deepseek-v3.2: Ok